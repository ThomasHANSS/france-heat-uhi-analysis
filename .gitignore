# --- Données volumineuses (à ne pas pousser sur GitHub) ---
# Les CSV bruts Météo-France et les rasters LCZ sont volumineux.
# On versionne uniquement les scripts et les résultats agrégés.

data/raw/meteo_france/*.csv
data/raw/cerema_lcz/*.zip
data/raw/cerema_lcz/*.shp
data/raw/cerema_lcz/*.shx
data/raw/cerema_lcz/*.dbf
data/raw/cerema_lcz/*.prj
data/raw/cerema_lcz/*.cpg
data/raw/cerema_lcz/*.qml
data/raw/cerema_lcz/*.xml
data/raw/cerema_lcz/*.tif
data/raw/cerema_lcz/*.tfw
data/raw/cerema_lcz/*.pdf
data/raw/demuzere_lcz/*.tif
data/raw/demuzere_lcz/*.zip

# On garde les .gitkeep pour préserver les dossiers
!data/raw/*/.gitkeep
!data/stations/.gitkeep
!data/processed/.gitkeep
!data/results/.gitkeep

# Cerema LCZ : ignorer fichiers volumineux dans tous les sous-dossiers
data/raw/cerema_lcz/**/*.shp
data/raw/cerema_lcz/**/*.shx
data/raw/cerema_lcz/**/*.dbf
data/raw/cerema_lcz/**/*.prj
data/raw/cerema_lcz/**/*.cpg
data/raw/cerema_lcz/**/*.qml
data/raw/cerema_lcz/**/*.tif
data/raw/cerema_lcz/**/*.pdf
data/raw/cerema_lcz/**/*.xml
data/raw/cerema_lcz/**/*.zip

# Archives racine
*.zip
logs/

# --- Joly 2010 typologie (raster INRAE) ---
# Raster volumineux téléchargeable via API Dataverse (DOI INRAE 10.15454/98BHVH)
# Voir scripts/06_attribute_joly_climate.py pour téléchargement
data/raw/joly_2010/*.tif
data/raw/joly_2010/*.zip

# Données traitées intermédiaires lourdes (régénérables)
data/processed/**/intermediate_*

# Mais on garde les fichiers de référence stables (petits, à versionner)
# Implicite via les règles ci-dessus (rien ne les ignore)
